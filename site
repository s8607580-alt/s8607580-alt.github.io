<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Бункер бобра | Империя в Minecraft</title>
    <!-- Шрифты: Minecraft-like и современный -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: #1a1e2a;
            color: #e0e0e0;
            line-height: 1.5;
            scroll-behavior: smooth;
            background-image: 
                linear-gradient(rgba(26, 30, 42, 0.95), rgba(26, 30, 42, 0.95)),
                url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" width="100" height="100" fill="%23333a4f"><rect width="10" height="10" x="0" y="0"/><rect width="10" height="10" x="20" y="20"/><rect width="10" height="10" x="40" y="40"/><rect width="10" height="10" x="60" y="60"/><rect width="10" height="10" x="80" y="80"/></svg>');
            background-size: 50px 50px;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 24px;
        }

        /* Навбар в стиле Minecraft */
        .navbar {
            background-color: #0e0e1a;
            border-bottom: 4px solid #4a6b2f;
            position: sticky;
            top: 0;
            z-index: 100;
            box-shadow: 0 4px 0 #2a3a1e;
        }

        .nav-container {
            display: flex;
            justify-content: space-between;
            align-items: center;
            height: 80px;
        }

        .logo {
            font-family: 'Press Start 2P', cursive;
            font-size: 1.2rem;
            background: linear-gradient(135deg, #a5d6a5, #6b8c4a);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            text-shadow: 2px 2px 0 #2a3a1e;
        }

        .nav-links {
            display: flex;
            gap: 32px;
            list-style: none;
        }

        .nav-links a {
            text-decoration: none;
            color: #c0c0c0;
            font-weight: 500;
            transition: color 0.2s;
            font-size: 0.95rem;
            letter-spacing: 0.5px;
        }

        .nav-links a:hover {
            color: #a5d6a5;
            text-shadow: 0 0 8px #6b8c4a;
        }

        .btn {
            display: inline-block;
            background-color: #4a6b2f;
            color: white;
            font-weight: 600;
            padding: 10px 24px;
            border-radius: 0;
            text-decoration: none;
            transition: all 0.1s;
            border: 2px solid #2a3a1e;
            font-family: 'Press Start 2P', cursive;
            font-size: 0.7rem;
            text-transform: uppercase;
            box-shadow: 0 4px 0 #2a3a1e;
            cursor: pointer;
        }

        .btn:hover {
            background-color: #5f8b3a;
            transform: translateY(-2px);
            box-shadow: 0 6px 0 #2a3a1e;
        }

        .btn:active {
            transform: translateY(4px);
            box-shadow: 0 0 0 #2a3a1e;
        }

        .btn-outline {
            background-color: transparent;
            color: #a5d6a5;
            border: 2px solid #a5d6a5;
            box-shadow: 0 4px 0 #4a6b2f;
        }

        /* Герой секция */
        .hero {
            padding: 80px 0;
            background: linear-gradient(145deg, #141a24, #1e2636);
            border-bottom: 4px solid #4a6b2f;
            position: relative;
            overflow: hidden;
        }

        .hero::before {
            content: "⛏️";
            font-size: 15rem;
            position: absolute;
            bottom: -30px;
            right: 10px;
            opacity: 0.05;
            transform: rotate(10deg);
        }

        .hero .container {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 48px;
            align-items: center;
            position: relative;
            z-index: 2;
        }

        .hero-content h1 {
            font-family: 'Press Start 2P', cursive;
            font-size: 2.2rem;
            line-height: 1.4;
            margin-bottom: 24px;
            color: #a5d6a5;
            text-shadow: 3px 3px 0 #2a3a1e;
        }

        .hero-content p {
            font-size: 1.2rem;
            color: #b0b0b0;
            margin-bottom: 32px;
            max-width: 500px;
        }

        .hero-buttons {
            display: flex;
            gap: 16px;
            flex-wrap: wrap;
        }

        .hero-image {
            background: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 300" fill="%234a6b2f"><rect x="50" y="100" width="60" height="60" fill="%238b5a2b"/><rect x="110" y="100" width="60" height="60" fill="%23a06b3a"/><rect x="170" y="100" width="60" height="60" fill="%238b5a2b"/><rect x="230" y="100" width="60" height="60" fill="%23a06b3a"/><rect x="50" y="160" width="60" height="60" fill="%23a06b3a"/><rect x="110" y="160" width="60" height="60" fill="%238b5a2b"/><rect x="170" y="160" width="60" height="60" fill="%23a06b3a"/><rect x="230" y="160" width="60" height="60" fill="%238b5a2b"/><rect x="110" y="220" width="120" height="40" fill="%235a3e1f"/><circle cx="160" cy="130" r="10" fill="%23f5f5dc"/><circle cx="210" cy="130" r="10" fill="%23f5f5dc"/></svg>') no-repeat center;
            background-size: contain;
            min-height: 300px;
            image-rendering: pixelated;
            filter: drop-shadow(0 10px 10px #00000080);
        }

        /* Секция с иерархией */
        .hierarchy {
            padding: 80px 0;
            background-color: #0f131e;
            border-bottom: 4px solid #4a6b2f;
        }

        .section-title {
            font-family: 'Press Start 2P', cursive;
            text-align: center;
            font-size: 2rem;
            margin-bottom: 16px;
            color: #a5d6a5;
            text-shadow: 2px 2px 0 #2a3a1e;
        }

        .section-subtitle {
            text-align: center;
            color: #a0a0a0;
            font-size: 1rem;
            max-width: 600px;
            margin: 0 auto 60px;
            font-family: 'Press Start 2P', cursive;
            line-height: 1.6;
        }

        .hierarchy-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
            gap: 32px;
        }

        .hierarchy-card {
            background: #1e2636;
            padding: 32px 24px;
            border-radius: 0;
            text-align: center;
            border: 3px solid #4a6b2f;
            box-shadow: inset 0 -4px 0 #2a3a1e, 0 8px 0 #0a0f1a;
            transition: transform 0.1s;
        }

        .hierarchy-card:hover {
            transform: translateY(-5px);
            box-shadow: inset 0 -4px 0 #2a3a1e, 0 12px 0 #0a0f1a;
        }

        .card-icon {
            font-size: 3rem;
            margin-bottom: 16px;
            filter: drop-shadow(2px 2px 0 #2a3a1e);
        }

        .hierarchy-card h3 {
            font-family: 'Press Start 2P', cursive;
            font-size: 1.1rem;
            margin-bottom: 16px;
            color: #a5d6a5;
        }

        .player-name {
            font-size: 1.2rem;
            font-weight: 600;
            color: #fff;
            background: #2a3a1e;
            display: inline-block;
            padding: 6px 12px;
            margin: 8px 0 4px;
            border: 2px solid #4a6b2f;
        }

        .player-nick {
            color: #bebebe;
            font-size: 0.9rem;
        }

        .role-tag {
            display: inline-block;
            background: #4a6b2f;
            color: #fff;
            padding: 4px 8px;
            font-size: 0.7rem;
            font-family: 'Press Start 2P', cursive;
            margin-bottom: 10px;
            border: 1px solid #2a3a1e;
        }

        /* Секция команды */
        .team {
            padding: 80px 0;
            background-color: #1a1e2a;
        }

        .team-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 24px;
            margin-top: 40px;
        }

        .team-member {
            background: #0f131e;
            border: 3px solid #4a6b2f;
            padding: 24px 12px;
            text-align: center;
            box-shadow: 0 6px 0 #0a0f1a;
        }

        .member-rank {
            font-family: 'Press Start 2P', cursive;
            font-size: 0.6rem;
            background: #4a6b2f;
            color: #fff;
            padding: 4px 6px;
            display: inline-block;
            margin-bottom: 12px;
        }

        .member-photo {
            width: 100px;
            height: 100px;
            margin: 0 auto 16px;
            background: #2a3a1e;
            border: 4px solid #6b8c4a;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2.5rem;
            image-rendering: pixelated;
            box-shadow: inset 0 0 0 2px #0a0f1a;
        }

        .team-member h3 {
            font-family: 'Press Start 2P', cursive;
            font-size: 0.9rem;
            color: #a5d6a5;
            margin-bottom: 6px;
            word-break: break-word;
        }

        .member-nick {
            color: #b0b0b0;
            font-size: 0.8rem;
            margin-bottom: 12px;
        }

        .minecraft-icon {
            font-size: 1.2rem;
            color: #6b8c4a;
            margin: 0 4px;
        }

        /* Рабы */
        .slave-row {
            display: flex;
            justify-content: center;
            gap: 20px;
            flex-wrap: wrap;
            margin-top: 40px;
        }

        .slave-card {
            background: #1e1e2a;
            border: 3px solid #8b4a4a;
            padding: 16px 24px;
            display: flex;
            align-items: center;
            gap: 16px;
            box-shadow: 0 6px 0 #4a2a2a;
        }

        .slave-icon {
            font-size: 2rem;
            filter: drop-shadow(2px 2px 0 #4a2a2a);
        }

        .slave-info h4 {
            font-family: 'Press Start 2P', cursive;
            font-size: 0.9rem;
            color: #d6a5a5;
            margin-bottom: 4px;
        }

        .slave-info p {
            font-size: 1.1rem;
            font-weight: 600;
        }

        /* Секция заявления на гражданство */
        .application {
            padding: 80px 0;
            background: #0f131e;
            border-top: 4px solid #4a6b2f;
            border-bottom: 4px solid #4a6b2f;
        }

        .application-container {
            max-width: 800px;
            margin: 0 auto;
            background: #1e2636;
            padding: 48px;
            border: 3px solid #4a6b2f;
            box-shadow: 0 8px 0 #0a0f1a;
        }

        .application-container h3 {
            font-family: 'Press Start 2P', cursive;
            font-size: 1.5rem;
            color: #a5d6a5;
            margin-bottom: 16px;
            text-align: center;
        }

        .application-container > p {
            text-align: center;
            color: #c0c0c0;
            margin-bottom: 32px;
            font-size: 0.9rem;
        }

        .application-form {
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .form-group input,
        .form-group textarea,
        .form-group select {
            width: 100%;
            padding: 14px 20px;
            background: #0a0f1a;
            border: 3px solid #4a6b2f;
            color: #fff;
            font-family: inherit;
            font-size: 1rem;
        }

        .form-group input:focus,
        .form-group textarea:focus,
        .form-group select:focus {
            outline: none;
            border-color: #a5d6a5;
        }

        .form-group textarea {
            min-height: 120px;
            resize: vertical;
        }

        .form-group select {
            appearance: none;
            background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='16' height='16' viewBox='0 0 24 24' fill='none' stroke='%234a6b2f' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><polyline points='6 9 12 15 18 9'/></svg>");
            background-repeat: no-repeat;
            background-position: right 20px center;
            background-size: 16px;
        }

        .checkbox-group {
            display: flex;
            align-items: center;
            gap: 12px;
            color: #c0c0c0;
        }

        .checkbox-group input[type="checkbox"] {
            width: 20px;
            height: 20px;
            accent-color: #4a6b2f;
        }

        /* Секция проверки статуса */
        .status-check {
            padding: 60px 0;
            background-color: #1a1e2a;
            border-bottom: 4px solid #4a6b2f;
        }

        .status-container {
            max-width: 600px;
            margin: 0 auto;
            background: #0f131e;
            padding: 40px;
            border: 3px solid #4a6b2f;
            text-align: center;
        }

        .status-container h3 {
            font-family: 'Press Start 2P', cursive;
            font-size: 1.3rem;
            color: #a5d6a5;
            margin-bottom: 20px;
        }

        .status-container p {
            color: #c0c0c0;
            margin-bottom: 30px;
        }

        .status-search {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
        }

        .status-search input {
            flex: 1;
            padding: 14px 20px;
            background: #0a0f1a;
            border: 3px solid #4a6b2f;
            color: #fff;
            font-family: inherit;
            font-size: 1rem;
        }

        .status-result {
            margin-top: 30px;
            padding: 20px;
            border: 2px solid #4a6b2f;
            background: #1a1e2a;
            display: none;
        }

        .status-result.show {
            display: block;
        }

        .status-approved {
            color: #a5d6a5;
            font-family: 'Press Start 2P', cursive;
            font-size: 0.9rem;
        }

        .status-pending {
            color: #ffaa00;
            font-family: 'Press Start 2P', cursive;
            font-size: 0.9rem;
        }

        .status-rejected {
            color: #ff5555;
            font-family: 'Press Start 2P', cursive;
            font-size: 0.9rem;
        }

        /* Футер */
        .footer {
            background: #0a0f1a;
            color: #a0a0a0;
            padding: 48px 0 24px;
            border-top: 4px solid #4a6b2f;
        }

        .footer-content {
            display: grid;
            grid-template-columns: 2fr 1fr 1fr;
            gap: 48px;
            margin-bottom: 48px;
        }

        .footer-logo {
            font-family: 'Press Start 2P', cursive;
            font-size: 1.2rem;
            background: linear-gradient(135deg, #a5d6a5, #6b8c4a);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 16px;
            display: inline-block;
        }

        .social-icons {
            display: flex;
            gap: 20px;
            margin-top: 20px;
        }

        .social-icons i {
            font-size: 1.5rem;
            color: #4a6b2f;
            transition: color 0.2s;
        }

        .footer-links h4 {
            color: #a5d6a5;
            margin-bottom: 20px;
            font-family: 'Press Start 2P', cursive;
            font-size: 0.9rem;
        }

        .footer-links ul {
            list-style: none;
        }

        .footer-links li {
            margin-bottom: 12px;
        }

        .footer-links a {
            color: #a0a0a0;
            text-decoration: none;
        }

        .footer-links a:hover {
            color: #a5d6a5;
        }

        .footer-bottom {
            text-align: center;
            padding-top: 32px;
            border-top: 2px solid #2a3a1e;
            color: #6a6a6a;
        }

        /* Инструкция по публикации */
        .publish-info {
            background: #0e0e1a;
            color: #a0a0a0;
            padding: 20px;
            text-align: center;
            border-bottom: 4px solid #4a6b2f;
            font-size: 0.9rem;
        }

        .publish-info a {
            color: #a5d6a5;
            text-decoration: none;
        }

        .publish-info a:hover {
            text-decoration: underline;
        }

        @media (max-width: 768px) {
            .hero .container {
                grid-template-columns: 1fr;
            }
            .nav-links {
                display: none;
            }
            .logo {
                font-size: 0.9rem;
            }
            .application-container {
                padding: 24px;
            }
            .status-search {
                flex-direction: column;
            }
        }
    </style>
</head>
<body>
    <!-- Информация о публикации (будет видна только при просмотре файла локально) -->
    <div class="publish-info">
        <i class="fas fa-globe"></i> Сайт готов к публикации! Инструкция: <a href="#publish">как разместить в интернете</a>
    </div>

    <nav class="navbar">
        <div class="container nav-container">
            <span class="logo">Бункер бобра</span>
            <ul class="nav-links">
                <li><a href="#home">Бункер</a></li>
                <li><a href="#hierarchy">Иерархия</a></li>
                <li><a href="#team">Команда</a></li>
                <li><a href="#application">Заявление</a></li>
                <li><a href="#status">Статус</a></li>
            </ul>
            <a href="#application" class="btn">Подать заявку</a>
        </div>
    </nav>

    <!-- Герой -->
    <section id="home" class="hero">
        <div class="container">
            <div class="hero-content">
                <h1>Бункер бобра<br>Minecraft империя</h1>
                <p>Построй своё будущее в суровом мире блоков. У нас есть президент, депутат, граждане и... рабы. Выбирай свою роль!</p>
                <div class="hero-buttons">
                    <a href="#application" class="btn">Подать заявление</a>
                    <a href="#hierarchy" class="btn btn-outline">Иерархия</a>
                </div>
            </div>
            <div class="hero-image" aria-label="Minecraft постройка"></div>
        </div>
    </section>

    <!-- Иерархия -->
    <section id="hierarchy" class="hierarchy">
        <div class="container">
            <h2 class="section-title">Иерархия империи</h2>
            <p class="section-subtitle">Каждый знает своё место</p>
            <div class="hierarchy-grid">
                <div class="hierarchy-card">
                    <div class="card-icon">👑</div>
                    <h3>Создатель (президент)</h3>
                    <div class="player-name">deku22</div>
                    <div class="role-tag">Верховный бобёр</div>
                    <p class="player-nick">Основатель и правитель</p>
                </div>
                <div class="hierarchy-card">
                    <div class="card-icon">⚖️</div>
                    <h3>Помощник создателя (депутат)</h3>
                    <div class="player-name">Semka_30328</div>
                    <div class="role-tag">Правая лапа</div>
                    <p class="player-nick">Следит за порядком</p>
                </div>
                <div class="hierarchy-card">
                    <div class="card-icon">🏡</div>
                    <h3>Полноправный гражданин</h3>
                    <div class="player-name">Abmin20013</div>
                    <div class="role-tag">Уважаемый бобёр</div>
                    <p class="player-nick">Имеет право голоса</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Команда + рабы -->
    <section id="team" class="team">
        <div class="container">
            <h2 class="section-title">Правящая элита</h2>
            <p class="section-subtitle">Те, кто строит империю</p>
            
            <div class="team-grid">
                <div class="team-member">
                    <div class="member-rank">ПРЕЗИДЕНТ</div>
                    <div class="member-photo">👑</div>
                    <h3>deku22</h3>
                    <div class="member-nick">Создатель</div>
                    <div><i class="fas fa-crown minecraft-icon"></i><i class="fas fa-hammer minecraft-icon"></i></div>
                </div>
                <div class="team-member">
                    <div class="member-rank">ДЕПУТАТ</div>
                    <div class="member-photo">⚡</div>
                    <h3>Semka_30328</h3>
                    <div class="member-nick">Помощник</div>
                    <div><i class="fas fa-gavel minecraft-icon"></i></div>
                </div>
                <div class="team-member">
                    <div class="member-rank">ГРАЖДАНИН</div>
                    <div class="member-photo">🏠</div>
                    <h3>Abmin20013</h3>
                    <div class="member-nick">Полноправный</div>
                    <div><i class="fas fa-tree minecraft-icon"></i></div>
                </div>
            </div>

            <!-- Отдельный блок для рабов -->
            <h3 style="font-family: 'Press Start 2P', cursive; text-align: center; margin: 60px 0 30px; color: #b88686; text-shadow: 2px 2px 0 #4a2a2a;">Рабы империи</h3>
            <div class="slave-row">
                <div class="slave-card">
                    <div class="slave-icon">⛓️</div>
                    <div class="slave-info">
                        <h4>РАБ</h4>
                        <p>MaxyStar_mc</p>
                    </div>
                </div>
                <div class="slave-card">
                    <div class="slave-icon">⛓️</div>
                    <div class="slave-info">
                        <h4>РАБ</h4>
                        <p>Rus_ka99</p>
                    </div>
                </div>
            </div>
            <p style="text-align: center; color: #a0a0a0; margin-top: 20px; font-style: italic;">* Рабы добывают ресурсы для величия бункера</p>
        </div>
    </section>

    <!-- Заявление на гражданство (без возраста) -->
    <section id="application" class="application">
        <div class="container">
            <div class="application-container">
